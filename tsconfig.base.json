      "@devngn/evals": ["./packages/evals/src/index.ts"],
      "@devngn/grounding": ["./packages/grounding/src/index.ts"],
      "@devngn/patterns": ["./packages/patterns/src/index.ts"],
      "@devngn/research": ["./packages/research/src/index.ts"],
      "@devngn/skills": ["./packages/skills/src/index.ts"],
      "@devngn/sync": ["./packages/sync/src/index.ts"],
      "@devngn/vendors": ["./packages/vendors/src/index.ts"],
      "@devngn/wellness-types": ["./packages/wellness-types/src/index.ts"]

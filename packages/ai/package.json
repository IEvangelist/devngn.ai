{
  "name": "@devngn/ai",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-aware AI runtime, token budgeting, and SDK capability contracts for devngn.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@devngn/core": "workspace:*",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "@google/genai": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}

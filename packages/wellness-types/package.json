{
  "name": "@devngn/wellness-types",
  "version": "0.0.0",
  "private": true,
  "description": "Types-only TypeScript surface for the devngn.ai Wellness API, generated from its OpenAPI document.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "openapi-typescript ../../services/Devngn.Wellness.Api/openapi/v1.json --output ./src/schema.ts && node -e \"require('fs').copyFileSync('../../services/Devngn.Wellness.Api/openapi/v1.json','./src/openapi.json')\"",
    "generate:check": "pnpm generate && git diff --exit-code -- src/schema.ts src/openapi.json",
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "openapi-typescript": "^7.9.1"
  }
}

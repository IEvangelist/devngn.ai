{
  "name": "@devngn/wellness-apphost",
  "version": "0.0.0",
  "private": true,
  "description": "Aspire AppHost that orchestrates Postgres and the Devngn.Wellness.Api .NET service for local development.",
  "license": "MIT",
  "author": "David Pine",
  "type": "module",
  "scripts": {
    "restore": "aspire restore",
    "build:site": "pnpm --filter @devngn/site build",
    "start": "pnpm run build:site && aspire start",
    "start:isolated": "pnpm run build:site && aspire start --isolated"
  },
  "dependencies": {
    "vscode-jsonrpc": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}

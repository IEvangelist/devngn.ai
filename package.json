{
  "name": "devngn.ai",
  "version": "0.0.0",
  "private": true,
  "description": "devngn.ai - the dev engine for managing your AI-bits.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev:site": "pnpm --filter @devngn/site dev",
    "dev:cli": "pnpm --filter @devngn/cli dev",
    "scan": "pnpm --filter @devngn/cli dev -- scan"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devngn",
  "version": "0.0.1-alpha.420",
  "identifier": "ai.devngn.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @devngn/app dev",
    "beforeBuildCommand": "pnpm --filter @devngn/app generate",
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "devngn",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://localhost:7107 http://localhost:5138 https://api.devngn.ai ws://localhost:* wss://localhost:*; img-src 'self' data: https://avatars.githubusercontent.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; script-src-attr 'none'; worker-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Gamified wellness interruptions for developers"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["devngn"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBM0Y0OTQ3QkI3MzgxMDgKUldRSWdYTzdSMGsvR2w1dlI1MGtvbTgrRTRpa2t6YnRNcE94Tk5GRGJ6YlprSGlPZS9RYTVXeFAK",
      "endpoints": [
        "https://github.com/IEvangelist/devngn.ai/releases/latest/download/latest.json"
      ],
      "windows": {
        "installerArgs": [],
        "installMode": "passive"
      }
    }
  }
}

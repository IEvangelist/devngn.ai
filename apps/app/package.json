{
  "name": "@devngn/app",
  "version": "0.0.0",
  "private": true,
  "description": "devngn.ai flagship app — a Tauri v2 desktop app and installable PWA for the wellness interruption engine, gamification, and social features.",
  "type": "module",
  "scripts": {
    "build:deps": "pnpm --filter \"@devngn/app^...\" build",
    "dev": "pnpm build:deps && nuxt dev",
    "build": "pnpm build:deps && nuxt build",
    "generate": "pnpm build:deps && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "nuxt typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@devngn/wellness-client": "workspace:*",
    "@devngn/wellness-types": "workspace:*",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-deep-link": "^2.4.0",
    "@tauri-apps/plugin-notification": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.3.0",
    "@tauri-apps/plugin-os": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-store": "^2.4.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "nuxt": "^4.2.1",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxtjs/i18n": "^10.2.0",
    "@pinia/nuxt": "^0.11.2",
    "@playwright/test": "^1.56.0",
    "@tauri-apps/cli": "^2.9.4",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "happy-dom": "^20.10.6",
    "pinia": "^3.0.3",
    "serve": "^14.2.4",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.4"
  }

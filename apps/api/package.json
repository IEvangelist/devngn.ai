{
  "name": "@devngn/api",
  "version": "0.0.0",
  "private": true,
  "description": "Hosted devngn API contracts for sync and analytics.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "test": "vitest run src/index.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@devngn/ai": "workspace:*",
    "@devngn/analytics": "workspace:*",
    "@devngn/grounding": "workspace:*",
    "@devngn/patterns": "workspace:*",
    "@devngn/sync": "workspace:*",
    "@devngn/vendors": "workspace:*",
    "zod": "^4.3.6"
  }
}

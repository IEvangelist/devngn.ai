{
  "name": "devngn-ai-vscode",
  "displayName": "devngn.ai",
  "description": "Manage your AI-bits from VS Code.",
  "version": "0.0.0",
  "publisher": "devngn",
  "private": true,
  "type": "commonjs",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:devngn.scan",
    "onCommand:devngn.openTokenUsage",
    "onView:devngn.aiBits",
    "onView:devngn.tokenUsage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devngn.scan",
        "title": "devngn: Scan AI-bits"
      },
      {
        "command": "devngn.openTokenUsage",
        "title": "devngn: Open Token Usage"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devngn",
          "title": "devngn",
          "icon": "media/devngn.svg"
        }
      ]
    },
    "views": {
      "devngn": [
        {
          "id": "devngn.aiBits",
          "name": "AI-bits",
          "icon": "media/devngn.svg"
        },
        {
          "id": "devngn.tokenUsage",
          "name": "Token Usage",
          "icon": "media/devngn.svg"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm build && node scripts/smoke-extension.cjs"
  },
  "dependencies": {
    "@devngn/ai": "workspace:*",
    "@devngn/analytics": "workspace:*",
    "@devngn/core": "workspace:*",
    "@devngn/patterns": "workspace:*",
    "@devngn/vendors": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0"
  }
}

---
/*
 * Unified site shell for every non-landing page (marketing, legal, registry,
 * API reference). Provides the uniform chrome David asked for: one sticky top
 * nav, one left sidebar, one right "On this page" TOC, and one footer, plus
 * Astro view transitions for smooth navigation. The Starlight docs are themed
 * to match this exact chrome, and both sidebars come from site-nav.ts.
 *
 * Static pages should `export const prerender = true`.
 */
import { ClientRouter } from "astro:transitions";
import ThemeInit from "../components/ThemeInit.astro";
import Motion from "../components/Motion.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteSidebar from "../components/SiteSidebar.astro";
import PageToc from "../components/PageToc.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/retro.css";
import "../styles/marketing.css";

interface Props {
  title: string;
  description: string;
  /** nav-links id to highlight in the header. */
  active?: string;
  /** OpenGraph type. */
  ogType?: string;
  /** Absolute or root-relative social share image. */
  image?: string;
  /** Show the left sidebar (default true). */
  sidebar?: boolean;
  /** Show the right "On this page" TOC (default true). */
  toc?: boolean;
  /** Constrain the content to a readable prose measure (legal/reference). */
  prose?: boolean;
}

const {
  title,
  description,
  active,
  ogType = "website",
  image = "/og.png",
  sidebar = true,
  toc = true,
  prose = false,
} = Astro.props;

const siteName = "devngn.ai";
const fullTitle = title.includes(siteName) ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <Motion />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#ec1c8b" />
    <meta name="generator" content={Astro.generator} />

    <!-- OpenGraph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
  </head>
  <body class="has-shell">
    <SiteHeader active={active} sidebar={sidebar} transition:persist="site-header" />
    <div class:list={["shell", { "no-sidebar": !sidebar, "no-toc": !toc }]}>
      <SiteSidebar />
      <main class:list={["shell-main", { prose }]}>
        <slot />
      </main>
      {toc && <PageToc />}
    </div>
    <SiteFooter transition:persist="site-footer" />
  </body>
</html>

---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Icon from "../components/Icon.astro";
import {
  anyDownloadAvailable,
  fetchReleaseAvailability,
  resolvePlatforms,
  type DesktopPlatform,
} from "../lib/release-info";

export const prerender = true;

const repo = "IEvangelist/devngn.ai";
const repoUrl = `https://github.com/${repo}`;
// Index of every release (never 404s, even before the first release). The
// stable per-asset "latest/download/…" URLs are built inside release-info.
const releasesUrl = `${repoUrl}/releases`;

// Desktop installers are stable-named assets on the latest *published* GitHub
// release, produced by the desktop app's workflow (app-release.yml). This
// build-time pass is the fail-safe source of truth (works with JS disabled and
// for crawlers) and avoids sending visitors to assets we cannot verify.
const platforms: DesktopPlatform[] = [
  {
    icon: "apple",
    os: "macOS",
    note: "Apple Silicon & Intel · macOS 13+",
    primary: { label: "Download for Apple Silicon", asset: "devngn-macos-aarch64.dmg" },
    secondary: [{ label: "Intel (x64)", asset: "devngn-macos-x64.dmg" }],
  },
  {
    icon: "windows",
    os: "Windows",
    note: "Windows 10 & 11 · x64",
    primary: { label: "Download installer", asset: "devngn-windows-x64-setup.exe" },
    secondary: [{ label: "MSI package", asset: "devngn-windows-x64.msi" }],
  },
  {
    icon: "linux",
    os: "Linux",
    note: "AppImage · Debian & Ubuntu",
    primary: { label: "Download AppImage", asset: "devngn-linux-x86_64.AppImage" },
    secondary: [{ label: ".deb (Debian/Ubuntu)", asset: "devngn-linux-amd64.deb" }],
  },
];

const availability = await fetchReleaseAvailability(repo, {
  token: process.env.GITHUB_TOKEN ?? process.env.GH_TOKEN,
});
const resolvedPlatforms = resolvePlatforms(repo, platforms, availability);
const hasDesktopDownloads = anyDownloadAvailable(resolvedPlatforms);
---

<MarketingLayout
  title="Download"
  description="Get devngn.ai on your machine: the desktop app for macOS, Windows, and Linux, plus the CLI and the VS Code extension. Open source, MIT licensed."
  active="download"
  sidebar={false}
  toc={false}
>
  <section class="page-hero">
    <div class="eyebrow">Download</div>
    <h1>Bring devngn to your <span class="hl">desktop</span>.</h1>
    <p class="lede">
      The desktop app keeps your dev engine and your wellness one click away, with streaks, goals, and
      right-timed movement breaks, right from the menu bar. Prefer the terminal or your editor?
      Those are here too.
    </p>
  </section>

  <section class="section" aria-label="Desktop app">
    <div class="section-kicker">Desktop app</div>
    <h2 class="section-title">Pick your platform.</h2>
    <p class="section-sub">
      Free and open source under the MIT license. Nothing personal is stored until you opt in, and
      you can delete all of it whenever you want.
    </p>
    <div class="dev-banner" role="status" data-dev-banner hidden={hasDesktopDownloads}>
      <span class="dev-banner-icon">
        <Icon name="rocket" size={22} stroke={2.6} />
      </span>
      <div class="dev-banner-body">
        <strong>Desktop builds are still on the workbench.</strong>
        <p>
          The native app is being built in the open and there's no public installer yet. Rather
          than hand you a download that 404s, we'll light these buttons up the moment the first
          release ships. Want the ping? Watch the repo's releases.
        </p>
        <div class="actions">
          <a class="btn primary" href={releasesUrl} rel="noopener" target="_blank">
            <Icon name="bell" size={18} stroke={2.6} />
            Watch releases
          </a>
          <a class="btn" href="/getting-started/">
            <Icon name="braces" size={18} stroke={2.6} />
            Build from source
          </a>
        </div>
      </div>
    </div>
    <div class="grid">
      {
        resolvedPlatforms.map((p) => (
          <article
            class="card platform"
            data-os={p.os.toLowerCase()}
            data-platform-card
            data-primary-asset={p.primary.asset}
            data-available={String(p.available)}
          >
            <div class="card-head">
              <span class="card-icon">
                <Icon name={p.icon} size={26} stroke={2.4} />
              </span>
              <h3>{p.os}</h3>
              <span class="platform-badge" data-badge-available>
                Your platform
              </span>
              <span class="platform-badge soon" data-badge-soon>
                Coming soon
              </span>
            </div>
            <p class="platform-note">{p.note}</p>
            <a class="btn primary platform-btn" data-primary-link href={p.primary.href}>
              <Icon name="download" size={18} stroke={2.6} />
              {p.primary.label}
            </a>
            <span class="btn platform-btn is-disabled" data-primary-disabled aria-disabled="true">
              <Icon name="clock" size={18} stroke={2.6} />
              Not yet available
            </span>
            <ul
              class="platform-alt"
              data-secondary
              hidden={!p.secondary.some((s) => s.available)}
            >
              {p.secondary.map((s) => (
                <li data-asset={s.asset} hidden={!s.available}>
                  <a href={s.href}>{s.label}</a>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
    <p class="release-note">
      Looking for a specific build, checksums, or release notes? Browse
      <a href={releasesUrl} rel="noopener" target="_blank">all releases on GitHub</a>.
    </p>
  </section>

  <section class="section" aria-label="Command line">
    <div class="section-kicker">Command line</div>
    <h2 class="section-title">Or live in the terminal.</h2>
    <p class="section-sub">
      The <code>devngn</code> CLI runs your scans, diagnostics, provider readiness, token budgets,
      grounding profiles, and pattern recognition.
    </p>
    <div class="code-block">
      <pre><code># In a repo, after installing dependencies
pnpm install
pnpm exec devngn scan

# Common commands
devngn doctor
devngn profile show
devngn ai providers
devngn patterns recognize</code></pre>
    </div>
  </section>

  <section class="section" aria-label="VS Code">
    <div class="section-kicker">In your editor</div>
    <h2 class="section-title">VS Code extension.</h2>
    <p class="section-sub">
      AI-bit inventory tree views, a token usage dashboard, provider readiness, and recognized
      ecosystem patterns, without leaving your editor.
    </p>
    <div class="actions">
      <a class="btn primary" href="/getting-started/">
        <Icon name="braces" size={18} stroke={2.6} />
        Getting started
      </a>
      <a class="btn" href={repoUrl} rel="noopener" target="_blank">
        <Icon name="github" size={18} stroke={2.6} />
        View source
      </a>
    </div>
  </section>

  <section class="cta-band">
    <h2>Every surface is <span class="pop">open source</span>. Take what you need.</h2>
    <div class="actions" style="margin-top:0">
      <a class="btn primary" href="/features/">See all features</a>
      <a class="btn alt" href="/getting-started/">Read the docs</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .platform {
    display: flex;
    flex-direction: column;
    border-top-width: 8px;
    border-top-color: var(--accent-2);
  }
  .platform[data-os="windows"] {
    border-top-color: var(--accent);
  }
  .platform[data-os="linux"] {
    border-top-color: var(--accent-3);
  }
  .platform .card-head {
    align-items: center;
  }
  .platform-badge {
    display: none;
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-ink);
    background: var(--accent-2);
    border: 2px solid var(--ink);
    padding: 0.15rem 0.4rem;
    white-space: nowrap;
  }
  .platform.is-detected {
    box-shadow: var(--shadow);
  }
  /* "Your platform" badge: only for the visitor's OS when it's downloadable. */
  .platform.is-detected[data-available="true"] .platform-badge[data-badge-available] {
    display: inline-block;
  }
  .platform-badge.soon {
    color: var(--ink);
    background: var(--accent-3);
  }
  /* "Coming soon" badge: whenever that platform has no downloadable installer. */
  .platform[data-available="false"] .platform-badge[data-badge-soon] {
    display: inline-block;
  }
  .platform[data-available="false"] {
    border-top-color: var(--muted);
    opacity: 0.92;
  }
  /* Show exactly one primary control based on live availability. */
  .platform[data-available="false"] [data-primary-link] {
    display: none;
  }
  .platform[data-available="true"] [data-primary-disabled] {
    display: none;
  }
  /* Honor the `hidden` attribute even when author rules set `display`. */
  .dev-banner[hidden],
  .platform-alt[hidden] {
    display: none;
  }
  .platform-btn.is-disabled {
    cursor: not-allowed;
    background: transparent;
    color: var(--muted);
    border-style: dashed;
    box-shadow: none;
  }
  .platform-btn.is-disabled:hover {
    transform: none;
    box-shadow: none;
  }
  .dev-banner {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    border: var(--border);
    border-left-width: 8px;
    border-left-color: var(--accent);
    background: var(--surface-bg);
    box-shadow: var(--shadow-sm);
    padding: 1.15rem 1.35rem;
    margin: 2rem 0 0;
  }
  .dev-banner-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 2.5rem;
    height: 2.5rem;
    border: 2px solid var(--ink);
    background: var(--accent);
    color: var(--accent-ink);
    box-shadow: var(--shadow-sm);
  }
  .dev-banner-body strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }
  .dev-banner-body p {
    margin: 0 0 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .dev-banner .actions {
    margin: 0;
  }
  .platform-note {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0 0 1.1rem;
  }
  .platform-btn {
    width: 100%;
    justify-content: center;
  }
  .platform-alt {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }
  .platform-alt a {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 1px;
  }
  .platform-alt a:hover {
    background: var(--accent-3);
    color: var(--accent-ink);
  }
  .release-note {
    margin-top: 1.75rem;
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .release-note a {
    color: var(--accent-ink);
    background: var(--accent-3);
    text-decoration: none;
    padding: 0 0.2em;
    border-bottom: 2px solid var(--accent);
  }
  .code-block {
    border: var(--border);
    background: #16130d;
    color: #f6eed6;
    box-shadow: var(--shadow);
    margin-top: 2rem;
    overflow-x: auto;
  }
  .code-block pre {
    margin: 0;
    padding: 1.4rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.7;
  }
  .code-block code {
    font-family: inherit;
  }
</style>

<script>
  import { parseReleaseAvailability } from "../lib/release-info";

  const REPO = "IEvangelist/devngn.ai";

  // Progressive enhancement: highlight the visitor's platform card.
  const detectPlatform = () => {
    const ua = navigator.userAgent;
    let os: string | null = null;
    if (/Macintosh|Mac OS X/.test(ua)) os = "macos";
    else if (/Windows/.test(ua)) os = "windows";
    else if (/Linux|X11/.test(ua) && !/Android/.test(ua)) os = "linux";
    document.querySelectorAll<HTMLElement>(".platform[data-os]").forEach((el) => {
      el.classList.toggle("is-detected", el.dataset.os === os);
    });
  };

  // Reconcile a positive build-time snapshot with what the latest *published*
  // release actually exposes right now. Every download link/button state is
  // already in the DOM; this only flips which ones are shown.
  const applyAvailability = (assets: Set<string>) => {
    let anyAvailable = false;

    document
      .querySelectorAll<HTMLElement>("[data-platform-card]")
      .forEach((card) => {
        const primary = card.dataset.primaryAsset ?? "";
        const available = assets.has(primary);
        card.dataset.available = String(available);
        if (available) anyAvailable = true;

        let anySecondary = false;
        card
          .querySelectorAll<HTMLLIElement>("[data-secondary] li[data-asset]")
          .forEach((li) => {
            const ok = assets.has(li.dataset.asset ?? "");
            li.hidden = !ok;
            if (ok) anySecondary = true;
          });

        const secondary = card.querySelector<HTMLElement>("[data-secondary]");
        if (secondary) secondary.hidden = !anySecondary;
      });

    const banner = document.querySelector<HTMLElement>("[data-dev-banner]");
    if (banner) banner.hidden = anyAvailable;
  };

  // Fail safe: any state we cannot positively verify (offline, rate-limited,
  // malformed JSON) leaves the build-time render untouched. When the build-time
  // render found no public desktop installer, skip the live GitHub probe
  // entirely; otherwise a private repo or "no release yet" state produces a
  // noisy browser 404 even though the UI already shows the safe coming-soon
  // state.
  const refreshAvailability = async () => {
    if (document.querySelector("[data-platform-card][data-available='true']") === null) {
      return;
    }

    let response: Response;
    try {
      response = await fetch(
        `https://api.github.com/repos/${REPO}/releases/latest`,
        {
          headers: {
            accept: "application/vnd.github+json",
            "x-github-api-version": "2022-11-28",
          },
        },
      );
    } catch {
      return;
    }

    if (response.status === 404) {
      applyAvailability(new Set());
      return;
    }
    if (!response.ok) return;

    try {
      const data = await response.json();
      applyAvailability(parseReleaseAvailability(data).assets);
    } catch {
      // Malformed payload — keep the build-time state.
    }
  };

  const enhance = () => {
    detectPlatform();
    void refreshAvailability();
  };

  // Re-runs on first load and after each Astro view transition.
  document.addEventListener("astro:page-load", enhance);
</script>

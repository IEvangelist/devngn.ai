---
import { listProviderManifests } from "@devngn/ai";
import { listImportantDevngnFlows } from "@devngn/analytics";
import { summarizePatternTrends } from "@devngn/patterns";
import { getBundledRegistry, getResearchFreshnessSummary } from "@devngn/vendors";
import ThemeInit from "../components/ThemeInit.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Icon from "../components/Icon.astro";
import "../styles/retro.css";

const vendors = getBundledRegistry();
const freshness = getResearchFreshnessSummary();
const providers = listProviderManifests();
const patternTrends = summarizePatternTrends();
const telemetryFlows = listImportantDevngnFlows();

const values = [
  {
    tag: "Aware",
    icon: "eye",
    body: "Opt in and build a wellness profile. devngn already knows your machine — now, with consent, it can respect the human at the keyboard.",
  },
  {
    tag: "Right-timed",
    icon: "clock",
    body: "Gap detection watches your real calendar and todos. Prompts arrive when a genuine opening appears, not when you're heads-down.",
  },
  {
    tag: "Effortless",
    icon: "bolt",
    body: "Five-second animated movement breaks, matched to your body and the equipment you actually have. No gym, no context switch.",
  },
  {
    tag: "Tracked",
    icon: "pulse",
    body: "Every break, streak, and goal is recorded. Progress is real and reviewable — not a vague intention to 'move more later'.",
  },
  {
    tag: "Goalified",
    icon: "target",
    body: "Turn wellbeing into concrete, measurable goals across mobility, strength, breathing, and posture, with progress events.",
  },
  {
    tag: "Gamified",
    icon: "trophy",
    body: "Streaks, milestones, and momentum turn healthy habits into something that actually sticks day after day.",
  },
  {
    tag: "Social",
    icon: "people",
    body: "Wellness is better together. Share goals and streaks with your team, cheer each other on, and stay honest.",
  },
  {
    tag: "Human-first",
    icon: "heart",
    body: "Consent-gated and private by design. Calendars are read free/busy only, nothing is stored until you say so, and you can delete it all.",
  },
];

const steps = [
  { n: "01", icon: "check", title: "Opt in", body: "Accept consent and sketch a profile: baseline, preferred intensity, and the gear within reach." },
  { n: "02", icon: "calendar", title: "We watch for real gaps", body: "Connect Google or Microsoft calendars (free/busy only) or push your own events. The engine finds true openings." },
  { n: "03", icon: "bell", title: "A 5-second nudge appears", body: "When a gap opens, a short movement-break prompt lands in VS Code or as an OS notification from the CLI daemon." },
  { n: "04", icon: "flame", title: "Track, share, and level up", body: "Complete it, build a streak, hit goals, and bring your team along. Small breaks, compounded." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>devngn.ai — Put the human first</title>
    <meta
      name="description"
      content="devngn.ai is human-first developer wellness. The moment a real gap opens in your schedule, get a five-second movement break tuned to your profile, goals, and equipment — tracked, shared, and social."
    />
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          repeating-linear-gradient(
            45deg,
            transparent 0 28px,
            rgba(127, 110, 70, 0.05) 28px 29px
          ),
          var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
      }
      a {
        color: inherit;
      }
      main {
        margin: 0 auto;
        max-width: 1140px;
        padding: 0 1.5rem 5rem;
      }

      .eyebrow {
        display: inline-block;
        font-family: var(--font-mono);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: 0.78rem;
        background: var(--ink);
        color: var(--bg);
        padding: 0.35rem 0.7rem;
      }

      /* Hero */
      .hero {
        display: grid;
        gap: 2.5rem;
        grid-template-columns: minmax(0, 1.5fr) minmax(17rem, 0.8fr);
        align-items: end;
        padding-top: 0.5rem;
      }
      h1 {
        font-family: var(--font-display);
        font-size: clamp(2.8rem, 8vw, 6rem);
        line-height: 1.12;
        letter-spacing: -0.03em;
        margin: 0.5rem 0 1rem;
        text-wrap: balance;
      }
      /* Solid retro block behind "human". A slightly looser line-height gives
         the block clearance so it hugs the word instead of bleeding up into
         the line above ("Put the"). */
      h1 .hl {
        background: var(--accent);
        color: var(--accent-ink);
        padding: 0 0.18em;
        -webkit-box-decoration-break: clone;
        box-decoration-break: clone;
      }
      .lede {
        font-size: 1.2rem;
        line-height: 1.65;
        max-width: 42rem;
        margin: 0 0 1rem;
      }
      .lede.small {
        font-size: 1.02rem;
        color: var(--muted);
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 1.75rem;
      }
      .btn {
        display: inline-block;
        font-family: var(--font-mono);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.92rem;
        text-decoration: none;
        padding: 0.85rem 1.3rem;
        border: var(--border);
        background: var(--surface-bg);
        color: var(--ink);
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.08s ease,
          box-shadow 0.08s ease;
      }
      .btn:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0 var(--shadow-color);
      }
      .btn:active {
        transform: translate(2px, 2px);
        box-shadow: 1px 1px 0 var(--shadow-color);
      }
      .btn.primary {
        background: var(--accent);
        color: var(--accent-ink);
      }
      .btn.alt {
        background: var(--accent-2);
        color: var(--accent-ink);
      }

      .stat-card {
        border: var(--border);
        background: var(--surface-bg);
        box-shadow: var(--shadow);
        padding: 1.5rem;
      }
      .stat {
        display: grid;
        gap: 0.1rem;
        padding: 0.75rem 0;
        border-bottom: 2px dashed var(--ink);
      }
      .stat:last-of-type {
        border-bottom: 0;
      }
      .stat span {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }
      .stat strong {
        font-family: var(--font-display);
        font-size: 2.2rem;
        line-height: 1;
      }
      .stat-card p {
        font-size: 0.9rem;
        color: var(--muted);
        margin: 0.75rem 0 0;
        line-height: 1.55;
      }

      /* Section heading */
      .section {
        margin-top: 5rem;
      }
      .section-kicker {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.78rem;
        color: var(--accent-ink);
        background: var(--accent-3);
        border: 2px solid var(--ink);
        display: inline-block;
        padding: 0.25rem 0.6rem;
      }
      h2.section-title {
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        letter-spacing: -0.02em;
        margin: 0.9rem 0 0.5rem;
        line-height: 1;
      }
      .section-sub {
        font-size: 1.05rem;
        color: var(--muted);
        max-width: 44rem;
        margin: 0;
        line-height: 1.6;
      }

      /* Mission band */
      .mission {
        margin-top: 4rem;
        border: var(--border);
        background: #16130d;
        color: var(--paper);
        box-shadow: var(--shadow-lg);
        padding: 2.5rem 2rem;
      }
      .mission p {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3.5vw, 2.4rem);
        line-height: 1.12;
        letter-spacing: -0.02em;
        margin: 0;
      }
      .mission p .pop {
        color: var(--accent-3);
      }
      .mission .by {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.78rem;
        color: var(--accent-3);
        margin-top: 1.25rem;
      }

      /* Value grid */
      .grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
        margin-top: 2rem;
      }
      .card {
        border: var(--border);
        background: var(--surface-bg);
        box-shadow: var(--shadow-sm);
        padding: 1.25rem;
        transition:
          transform 0.08s ease,
          box-shadow 0.08s ease;
      }
      .card:hover {
        transform: translate(-2px, -2px);
        box-shadow: var(--shadow);
      }
      .card-head {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.75rem;
      }
      .card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.1rem;
        height: 2.1rem;
        flex: none;
        border: 2px solid var(--ink);
        background: var(--surface-bg);
        color: var(--ink);
        box-shadow: var(--shadow-sm);
      }
      .card-icon :global(svg) {
        display: block;
      }
      .card .tag {
        display: inline-block;
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 1.05rem;
        text-transform: uppercase;
        letter-spacing: 0.01em;
        color: var(--accent-ink);
        border: 2px solid var(--ink);
        padding: 0.2rem 0.55rem;
        margin-bottom: 0;
      }
      .card:nth-child(8n + 1) .tag {
        background: var(--accent);
      }
      .card:nth-child(8n + 2) .tag {
        background: var(--accent-2);
      }
      .card:nth-child(8n + 3) .tag {
        background: var(--accent-3);
      }
      .card:nth-child(8n + 4) .tag {
        background: var(--accent-5);
      }
      .card:nth-child(8n + 5) .tag {
        background: var(--accent-6);
        color: var(--paper);
      }
      .card:nth-child(8n + 6) .tag {
        background: var(--accent-4);
        color: var(--paper);
      }
      .card:nth-child(8n + 7) .tag {
        background: var(--accent-2);
      }
      .card:nth-child(8n + 8) .tag {
        background: var(--accent-3);
      }
      .card p {
        margin: 0;
        line-height: 1.55;
        color: var(--text);
      }

      /* Steps */
      .steps {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
        margin-top: 2rem;
      }
      .step {
        border: var(--border);
        background: var(--surface-bg);
        box-shadow: var(--shadow-sm);
        padding: 1.25rem;
      }
      .step-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .step-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.4rem;
        height: 2.4rem;
        flex: none;
        border: 2px solid var(--ink);
        background: var(--accent);
        color: var(--accent-ink);
        box-shadow: var(--shadow-sm);
      }
      .step-icon :global(svg) {
        display: block;
      }
      .step .n {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 2.4rem;
        line-height: 1;
        color: var(--accent);
        -webkit-text-stroke: 1.5px var(--ink);
      }
      .step h3 {
        font-family: var(--font-display);
        font-size: 1.15rem;
        margin: 0.5rem 0 0.4rem;
        letter-spacing: -0.01em;
      }
      .step p {
        margin: 0;
        color: var(--muted);
        line-height: 1.5;
        font-size: 0.95rem;
      }

      /* Platform panels */
      .panels {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
        margin-top: 2rem;
      }
      .panel {
        border: var(--border);
        background: var(--surface-bg);
        box-shadow: var(--shadow-sm);
        padding: 1.25rem 1.4rem;
      }
      .panel h3 {
        font-family: var(--font-display);
        font-size: 1.05rem;
        margin: 0 0 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 2px solid var(--ink);
        letter-spacing: -0.01em;
      }
      .panel p {
        margin: 0;
        line-height: 1.55;
        color: var(--text);
      }
      .panel ul {
        margin: 0;
        padding-left: 1.1rem;
        line-height: 1.7;
        color: var(--text);
        font-size: 0.94rem;
      }
      .panel ul li::marker {
        color: var(--accent);
      }

      @media (max-width: 820px) {
        .hero {
          grid-template-columns: 1fr;
          align-items: start;
        }
      }
    </style>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="hero">
        <div>
          <div class="eyebrow">Human-first dev wellness</div>
          <h1>Put the <span class="hl">human</span> first.</h1>
          <p class="lede">
            devngn.ai honors the body behind the keyboard. The moment a real gap opens in your
            schedule, we nudge you with a five-second movement break — tuned to your profile, your
            goals, and the equipment you actually have.
          </p>
          <p class="lede small">
            Aware. Responsible. Built so engineers can turn their focus toward their own health —
            and the civilization they're building. Tracked, shared, goalified, and social.
          </p>
          <div class="actions">
            <a class="btn primary" href="/getting-started/">Read the docs</a>
            <a class="btn alt" href="/wellness/">Explore the wellness service</a>
            <a class="btn" href="/wellness/reference">Browse the API</a>
          </div>
        </div>
        <aside class="stat-card">
          <div class="stat">
            <span>Known vendors / tools</span>
            <strong>{freshness.total}</strong>
          </div>
          <div class="stat">
            <span>Movement-break catalog</span>
            <strong>5s</strong>
          </div>
          <div class="stat">
            <span>Stored from your calendar</span>
            <strong>free/busy</strong>
          </div>
          <p>
            Open source, MIT licensed. Nothing personal is stored until you opt in — and you can
            delete all of it whenever you want.
          </p>
        </aside>
      </section>

      <section class="mission">
        <p>
          Technology should serve the human — <span class="pop">not consume them.</span> We help
          developers move, breathe, and reset, so the people building the future stay healthy
          enough to enjoy it.
        </p>
        <div class="by">The devngn.ai promise · Copyright © 2026–Present David Pine · MIT</div>
      </section>

      <section class="section" aria-label="What we're about">
        <div class="section-kicker">What we're about</div>
        <h2 class="section-title">Wellness, woven into the workday.</h2>
        <p class="section-sub">
          Not another dashboard to check. A quiet, opt-in layer that turns the small gaps in a
          developer's day into real, compounding movement.
        </p>
        <div class="grid">
          {
            values.map((v) => (
              <article class="card">
                <div class="card-head">
                  <span class="card-icon">
                    <Icon name={v.icon} size={22} stroke={2.4} />
                  </span>
                  <span class="tag">{v.tag}</span>
                </div>
                <p>{v.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" aria-label="How it works">
        <div class="section-kicker">How it works</div>
        <h2 class="section-title">From sitting still to streaks.</h2>
        <div class="steps">
          {
            steps.map((s) => (
              <article class="step">
                <div class="step-head">
                  <div class="n">{s.n}</div>
                  <span class="step-icon">
                    <Icon name={s.icon} size={24} stroke={2.4} />
                  </span>
                </div>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" aria-label="The dev engine behind it">
        <div class="section-kicker">Under the hood</div>
        <h2 class="section-title">The dev engine behind it.</h2>
        <p class="section-sub">
          Wellness rides on devngn.ai — the engine that already understands your machine, tools, and
          AI-bits. Here's it running live, right now.
        </p>
        <div class="panels">
          <div class="panel">
            <h3>Research matrix</h3>
            <ul>
              {vendors.map((vendor) => <li>{vendor.name}: {vendor.research.status}</li>)}
            </ul>
          </div>
          <div class="panel">
            <h3>AI runtime providers</h3>
            <ul>
              {
                providers.map((provider) => (
                  <li>
                    {provider.name}: {provider.capabilities.join(", ")}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="panel">
            <h3>Pattern trends</h3>
            <p>
              Tracking {patternTrends.total} known ecosystem patterns, with {
                patternTrends.rising.length
              } rising and {patternTrends.watch.length} on watch.
            </p>
          </div>
          <div class="panel">
            <h3>OpenTelemetry coverage</h3>
            <p>
              Measuring {telemetryFlows.length} important dev engine flows with logs, traces, and
              metrics for Aspire dashboard visibility — including the {freshness.byStatus.planned ??
                0} planned vendor research runs.
            </p>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>

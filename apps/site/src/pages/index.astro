---
import { listProviderManifests } from "@devngn/ai";
import { listImportantDevngnFlows } from "@devngn/analytics";
import { summarizePatternTrends } from "@devngn/patterns";
import { getBundledRegistry, getResearchFreshnessSummary } from "@devngn/vendors";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Icon from "../components/Icon.astro";

// Live product data. Real proof, not mock numbers.
const vendors = getBundledRegistry();
const freshness = getResearchFreshnessSummary();
const providers = listProviderManifests();
const patternTrends = summarizePatternTrends();
const telemetryFlows = listImportantDevngnFlows();

const providerNames = providers.map((p) => p.name);

// Recognizable agents/runtimes devngn grounds. Real integrations, shown as a
// quick compatibility scan under the hero.
const worksWith = ["GitHub Copilot", "Claude", "Cursor", "OpenAI", "Gemini", "Ollama"];

// The visceral "why": what an ungrounded agent does when it can't see the machine.
const guesses = [
  "Calls an MCP server you removed weeks ago",
  "Writes to a config path that never existed",
  "Assumes a model you never set up",
  "Skips the rules sitting right there in your repo",
];

// Left column of the split: the dev engine.
const enginePoints = [
  {
    icon: "eye",
    title: "Discovers your AI-bits",
    body: "Finds the instructions, rules, MCP servers, model prefs, and provider config scattered across every workspace on your machine.",
  },
  {
    icon: "target",
    title: "Keeps agents grounded",
    body: "Grounds coding agents in what is actually installed and configured, so they stop guessing and start working from the truth.",
  },
  {
    icon: "pulse",
    title: "Flags drift and gaps",
    body: "Tracks provider readiness and token budgets across OpenAI, Copilot, Claude, Gemini, and local models, and surfaces what is stale.",
  },
];

// Right column of the split: human-first wellness.
const humanPoints = [
  {
    icon: "calendar",
    title: "Watches for real openings",
    body: "Consent-gated free/busy detection finds genuine gaps in your day. Prompts arrive when you are free, never mid-focus.",
  },
  {
    icon: "bolt",
    title: "Five-second movement breaks",
    body: "Short, guided resets tuned to your profile and the equipment you actually have. No gym, no context switch.",
  },
  {
    icon: "trophy",
    title: "Tracked, shared, yours",
    body: "Streaks, goals, and team sharing make healthy habits stick. Private by design, and deletable whenever you want.",
  },
];

// Live proof figures for the dark band.
const proof = [
  { value: String(freshness.total), label: "Vendors and tools tracked" },
  { value: String(providers.length), label: "AI runtime providers wired" },
  { value: String(patternTrends.total), label: "Ecosystem patterns watched" },
  { value: String(telemetryFlows.length), label: "Flows with full telemetry" },
];

// The wellness loop.
const loop = [
  { n: "01", icon: "check", title: "Opt in", body: "Accept consent and sketch a profile: baseline, intensity, and the gear within reach." },
  { n: "02", icon: "calendar", title: "Find the gap", body: "Connect Google or Microsoft calendars (free/busy only), or push your own events." },
  { n: "03", icon: "bell", title: "Take the break", body: "A five-second prompt lands in VS Code or as an OS notification from the CLI daemon." },
  { n: "04", icon: "flame", title: "Build the streak", body: "Complete it, keep the streak, hit goals, and bring your team along. Small breaks compound." },
];

const description =
  "devngn.ai grounds your AI coding agents in the truth of your machine, then protects the developer running them. One engine: AI-bit discovery and grounding, plus consent-gated developer wellness. Open source, MIT.";
---

<MarketingLayout
  title="devngn.ai · Ground your AI, protect the human"
  description={description}
  sidebar={false}
  toc={false}
>
  <div class="lp">
    <!-- Hero: asymmetric split, dual hook + live proof aside -->
    <section class="lp-hero">
      <div class="lp-hero-copy">
        <span class="eyebrow">Open source · free forever · desktop app + CLI</span>
        <h1>
          Ground your <span class="nb"><span class="hl a">AI</span>.</span><br />
          Protect the <span class="nb"><span class="hl b">human</span>.</span>
        </h1>
        <p class="lp-lede">
          Your AI agents guess at your setup. devngn grounds them in what is really installed, then
          guards the developer running them.
        </p>
        <div class="actions">
          <a class="btn primary" href="/download/"><Icon name="download" size={18} stroke={2.6} />Get the app</a>
          <a class="btn" href="#how">See how it works</a>
        </div>
      </div>

      <aside class="lp-proof-card" aria-label="What devngn knows right now">
        <p class="lp-proof-title">Live on your machine</p>
        <dl>
          <div>
            <dt>Vendors and tools</dt>
            <dd>{freshness.total}</dd>
          </div>
          <div>
            <dt>AI providers</dt>
            <dd>{providers.length}</dd>
          </div>
          <div>
            <dt>Stored from calendar</dt>
            <dd class="sm">free / busy</dd>
          </div>
        </dl>
        <p class="lp-proof-foot">
          MIT licensed. Nothing personal is stored until you opt in, and you can delete all of it.
        </p>
      </aside>
    </section>

    <!-- Compatibility strip: what devngn grounds. Concrete + real. -->
    <section class="lp-works" aria-label="Works with the agents you already run">
      <p class="lp-works-label">Grounds the agents you already run</p>
      <ul class="lp-works-list">
        {worksWith.map((name) => <li>{name}</li>)}
        <li class="more">+ local models</li>
      </ul>
    </section>

    <!-- The problem, made visceral: distinct mono "error" treatment. -->
    <section class="lp-blind" aria-label="Why grounding matters">
      <div class="lp-blind-copy">
        <h2>Agents guess. You clean up <span class="nb"><span class="hl a">the mess.</span></span></h2>
        <p>
          An agent that cannot see what is installed fills the gaps with assumptions. That is where
          the wrong turns start:
        </p>
      </div>
      <ul class="lp-blind-list">
        {
          guesses.map((g) => (
            <li>
              <span class="lp-blind-x"><Icon name="x" size={15} stroke={3} /></span>
              {g}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Dual positioning: two-column split, equal billing -->
    <section class="lp-duo" aria-label="One tool, two jobs">
      <header class="lp-duo-head">
        <h2>One tool. Two jobs it refuses to compromise.</h2>
        <p>
          Most tools help your agents or help you. devngn does both, because the code and the coder
          are the same system.
        </p>
      </header>
      <div class="lp-duo-cols">
        <div class="lp-col engine">
          <p class="lp-col-tag">The dev engine</p>
          <h3>Know your AI tooling, end to end.</h3>
          <ul class="lp-col-list">
            {
              enginePoints.map((p) => (
                <li>
                  <span class="lp-col-icon"><Icon name={p.icon} size={18} stroke={2.6} /></span>
                  <div>
                    <strong>{p.title}</strong>
                    <span>{p.body}</span>
                  </div>
                </li>
              ))
            }
          </ul>
          <a class="lp-col-link" href="/features/">Explore the engine <Icon name="arrow" size={15} stroke={2.8} /></a>
        </div>
        <div class="lp-col human">
          <p class="lp-col-tag alt">Human-first wellness</p>
          <h3>Protect the person at the keyboard.</h3>
          <ul class="lp-col-list">
            {
              humanPoints.map((p) => (
                <li>
                  <span class="lp-col-icon alt"><Icon name={p.icon} size={18} stroke={2.6} /></span>
                  <div>
                    <strong>{p.title}</strong>
                    <span>{p.body}</span>
                  </div>
                </li>
              ))
            }
          </ul>
          <a class="lp-col-link" href="/wellness/">Explore wellness <Icon name="arrow" size={15} stroke={2.8} /></a>
        </div>
      </div>
    </section>

    <!-- Live proof band: real data, full-width dark, inline figures -->
    <section class="lp-band" aria-label="Running live right now">
      <div class="lp-band-lead">
        <h2>Not a demo. This is running right now.</h2>
        <p>
          Every figure below comes straight from the bundled registry and runtime, rendered on each
          request. Providers online: {providerNames.join(", ")}.
        </p>
      </div>
      <div class="lp-band-figs">
        {
          proof.map((s) => (
            <div class="lp-fig">
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Engine deep-cut: two alternating rows (zigzag, capped at 2) -->
    <section class="lp-rows" aria-label="Inside the engine">
      <article class="lp-row">
        <div class="lp-row-copy">
          <p class="lp-row-kicker">Grounding</p>
          <h3>Your agents stop guessing.</h3>
          <p>
            devngn reads the real instructions, rules, and MCP config on disk and hands agents a
            grounded picture of the machine. Fewer hallucinated paths, fewer wrong assumptions, less
            cleanup after the fact.
          </p>
        </div>
        <div class="lp-row-art art-grounding" aria-hidden="true">
          <ul class="lp-chiplist">
            {vendors.slice(0, 6).map((v) => (
              <li><span class="dot"></span>{v.name}<em>{v.research.status}</em></li>
            ))}
          </ul>
        </div>
      </article>

      <article class="lp-row reverse">
        <div class="lp-row-copy">
          <p class="lp-row-kicker">Readiness</p>
          <h3>Every provider, one honest view.</h3>
          <p>
            Track auth and SDK readiness, token budgets, and model preferences across every provider
            you use, local models included. Know what is ready before an agent run, not after it
            fails halfway through.
          </p>
        </div>
        <div class="lp-row-art art-readiness" aria-hidden="true">
          <ul class="lp-provlist">
            {providers.map((p) => (
              <li><strong>{p.name}</strong><span>{p.capabilities.join(" · ")}</span></li>
            ))}
          </ul>
        </div>
      </article>
    </section>

    <!-- Wellness loop: numbered horizontal flow -->
    <section id="how" class="lp-flow" aria-label="How the wellness loop works">
      <header class="lp-flow-head">
        <h2>How the wellness loop works.</h2>
        <p>Opt in once. The engine already knows your machine, so it can respect the body running it.</p>
      </header>
      <ol class="lp-flow-steps">
        {
          loop.map((s) => (
            <li>
              <span class="lp-flow-n">{s.n}</span>
              <span class="lp-flow-icon"><Icon name={s.icon} size={20} stroke={2.6} /></span>
              <strong>{s.title}</strong>
              <span class="lp-flow-body">{s.body}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Final CTA band (shared marketing component) -->
    <section class="cta-band">
      <h2>Ready to ground your agents and <span class="pop">protect your team?</span></h2>
      <div class="actions">
        <a class="btn primary" href="/download/"><Icon name="download" size={18} stroke={2.6} />Get the app</a>
        <a class="btn alt" href="/getting-started/">Read the docs</a>
      </div>
    </section>
  </div>
</MarketingLayout>

<style>
  .lp {
    display: block;
  }

  /* Shared inline highlight blocks for the hero headline.
   * The highlight is painted as a fixed-height band (background-size) centered on
   * the text rather than filling the full display-font line box, so a highlighted
   * word on one line never overlaps the line above or below it. */
  .nb {
    white-space: nowrap;
  }
  .hl {
    color: var(--accent-ink);
    padding: 0 0.16em;
    background-repeat: no-repeat;
    background-position: left center;
    background-size: 100% 0.92em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .hl.a {
    background-image: linear-gradient(var(--accent), var(--accent));
  }
  .hl.b {
    background-image: linear-gradient(var(--accent-2), var(--accent-2));
  }

  /* ---- Hero: asymmetric split ------------------------------------------- */
  .lp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(14rem, 0.7fr);
    gap: 2rem;
    align-items: end;
    padding: 1.5rem 0 3rem;
    border-bottom: 3px solid var(--ink);
  }
  .lp-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.6vw, 4.25rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin: 1rem 0 1rem;
  }
  .lp-lede {
    font-size: 1.25rem;
    line-height: 1.55;
    max-width: 34rem;
    margin: 0;
    color: var(--text);
  }

  .lp-proof-card {
    border: var(--border);
    background:
      repeating-linear-gradient(
        45deg,
        transparent 0 22px,
        rgba(17, 179, 163, 0.08) 22px 23px
      ),
      var(--surface-bg);
    box-shadow: var(--shadow);
    padding: 1.4rem 1.5rem;
  }
  .lp-proof-title {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  .lp-proof-card dl {
    margin: 0;
  }
  .lp-proof-card dl > div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
    border-bottom: 2px dashed var(--ink);
  }
  .lp-proof-card dt {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }
  .lp-proof-card dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: var(--ink);
  }
  .lp-proof-card dd.sm {
    font-size: 1rem;
    letter-spacing: 0.02em;
  }
  .lp-proof-foot {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0.9rem 0 0;
  }

  /* ---- Compatibility strip --------------------------------------------- */
  .lp-works {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.1rem;
    padding: 1.25rem 0 0;
  }
  .lp-works-label {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--muted);
    margin: 0;
  }
  .lp-works-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
  }
  .lp-works-list li {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    background: var(--surface-bg);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-sm);
    padding: 0.28rem 0.6rem;
  }
  .lp-works-list li.more {
    background: transparent;
    border-style: dashed;
    color: var(--muted);
    box-shadow: none;
  }

  /* ---- The problem: distinct mono "error board" ------------------------- */
  .lp-blind {
    margin-top: 4.5rem;
  }
  .lp-blind-copy {
    max-width: 40rem;
  }
  .lp-blind-copy h2 {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 0 0 0.6rem;
  }
  .lp-blind-copy p {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
  }
  .lp-blind-list {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: var(--border);
    border-left-width: 8px;
    border-left-color: var(--accent);
    background: var(--surface-bg);
    box-shadow: var(--shadow);
  }
  .lp-blind-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 1.05rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--text);
    border-bottom: 2px dashed var(--ink);
  }
  .lp-blind-list li:nth-child(odd) {
    border-right: 2px dashed var(--ink);
  }
  .lp-blind-list li:nth-last-child(-n + 2) {
    border-bottom: none;
  }
  .lp-blind-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    width: 1.4rem;
    height: 1.4rem;
    margin-top: 0.05rem;
    color: var(--accent-ink);
    background: var(--accent);
    border: 2px solid var(--ink);
  }

  /* ---- Dual positioning: two-column split ------------------------------- */
  .lp-duo {
    margin-top: 4.5rem;
  }
  .lp-duo-head {
    max-width: 44rem;
  }
  .lp-duo-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 0 0 0.6rem;
  }
  .lp-duo-head p {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
  }
  .lp-duo-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .lp-col {
    border: var(--border);
    background: var(--surface-bg);
    box-shadow: var(--shadow);
    padding: 1.6rem 1.6rem 1.4rem;
    border-top-width: 8px;
  }
  .lp-col.engine {
    border-top-color: var(--accent);
  }
  .lp-col.human {
    border-top-color: var(--accent-2);
  }
  .lp-col-tag {
    display: inline-block;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent-ink);
    background: var(--accent);
    border: 2px solid var(--ink);
    padding: 0.25rem 0.55rem;
    margin: 0 0 0.75rem;
  }
  .lp-col-tag.alt {
    background: var(--accent-2);
  }
  .lp-col h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    line-height: 1.05;
    margin: 0 0 1.1rem;
  }
  .lp-col-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .lp-col-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .lp-col-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    flex: none;
    border: 2px solid var(--ink);
    background: var(--accent);
    color: var(--accent-ink);
    box-shadow: var(--shadow-sm);
  }
  .lp-col-icon.alt {
    background: var(--accent-2);
  }
  .lp-col-list strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.02rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.15rem;
  }
  .lp-col-list span {
    color: var(--text);
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .lp-col-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 3px solid var(--accent);
    padding-bottom: 2px;
  }
  .lp-col.human .lp-col-link {
    border-bottom-color: var(--accent-2);
  }
  .lp-col-link svg {
    display: block;
  }

  /* ---- Live proof band: full-width dark --------------------------------- */
  .lp-band {
    margin-top: 4.5rem;
    border: var(--border);
    background: #16130d;
    color: var(--paper);
    box-shadow: var(--shadow-lg);
    padding: 2.5rem 2rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 2rem;
    align-items: center;
  }
  .lp-band-lead h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.6rem;
  }
  .lp-band-lead p {
    margin: 0;
    line-height: 1.55;
    color: #d9cfb4;
    font-size: 0.98rem;
  }
  .lp-band-figs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .lp-fig {
    border: 2px solid var(--paper);
    padding: 1rem 1.1rem;
    background: #221c12;
  }
  .lp-fig strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 1;
    color: var(--accent-3);
  }
  .lp-fig span {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #d9cfb4;
  }

  /* ---- Engine deep-cut: alternating rows -------------------------------- */
  .lp-rows {
    margin-top: 4.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .lp-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
  }
  .lp-row.reverse .lp-row-copy {
    order: 2;
  }
  .lp-row-copy .lp-row-kicker {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    color: var(--accent-ink);
    background: var(--accent-3);
    border: 2px solid var(--ink);
    display: inline-block;
    padding: 0.2rem 0.55rem;
    margin: 0 0 0.75rem;
  }
  .lp-row-copy h3 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    letter-spacing: -0.02em;
    line-height: 1.03;
    margin: 0 0 0.6rem;
  }
  .lp-row-copy p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text);
    max-width: 32rem;
  }
  .lp-row-art {
    border: var(--border);
    box-shadow: var(--shadow);
    padding: 1.4rem;
    background: var(--surface-bg);
    min-height: 12rem;
  }
  .art-grounding {

---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Icon from "../components/Icon.astro";

export const prerender = true;

const capabilities = [
  {
    icon: "eye",
    title: "AI-bit discovery",
    body: "Finds the instructions, skills, rules, prompts, memories, model preferences, and vendor folders scattered across your machine and every workspace.",
  },
  {
    icon: "target",
    title: "Self-updating grounding",
    body: "Builds a live host profile (OS, CPU, GPU, memory, PATH tools, installed AI tools, and your stated preferences) so agents are grounded in reality.",
  },
  {
    icon: "bolt",
    title: "Provider readiness",
    body: "Tracks SDK/auth readiness, capability metadata, and token budgets for OpenAI, GitHub Copilot, Anthropic Claude, Google Gemini, and local runtimes.",
  },
  {
    icon: "spark",
    title: "Pattern intelligence",
    body: "Recognizes AGENTS.md, Copilot instructions, Claude memory, Cursor/Windsurf rules, MCP configs, promptfoo evals, Continue, and Cline/Roo rules.",
  },
  {
    icon: "pulse",
    title: "Drift & cleanup",
    body: "Surfaces duplicate guidance, tooling conflicts, stale AI-bits, and cleanup opportunities before they quietly rot your setup.",
  },
  {
    icon: "code",
    title: "Hosted registry & API",
    body: "Versioned public vendor registry plus a protected, subscriber-oriented vendor intelligence API with rate limits and plan-aware access.",
  },
];

const wellness = [
  {
    icon: "clock",
    title: "Right-timed nudges",
    body: "Gap detection watches your real calendar (free/busy only) and todos, so a five-second movement break lands when a genuine opening appears.",
  },
  {
    icon: "trophy",
    title: "Gamified & goalified",
    body: "Streaks, milestones, XP, and badges turn mobility, strength, breathing, and posture into concrete goals that actually stick.",
  },
  {
    icon: "people",
    title: "Social by design",
    body: "Share goals and streaks with your team, follow teammates, cheer each other on, and stay honest. Wellness is better together.",
  },
  {
    icon: "heart",
    title: "Human-first & private",
    body: "Consent-gated from the first byte. Calendars are read free/busy only, nothing is stored until you opt in, and you can delete all of it anytime.",
  },
];

const surfaces = [
  {
    icon: "code",
    title: "devngn CLI",
    body: "Scans, diagnostics, provider readiness, token budgeting, grounding profiles, pattern recognition, sync, and update checks, right in your terminal.",
    cta: { label: "Read the docs", href: "/getting-started/" },
  },
  {
    icon: "braces",
    title: "VS Code extension",
    body: "AI-bit inventory tree views, a token usage dashboard, provider readiness, and recognized ecosystem patterns without leaving your editor.",
    cta: { label: "Getting started", href: "/getting-started/" },
  },
  {
    icon: "download",
    title: "Desktop app",
    body: "A dedicated desktop experience for your dev engine and wellness, with streaks, goals, and social always a click away from the menu bar.",
    cta: { label: "Download", href: "/download/" },
  },
  {
    icon: "pulse",
    title: "OpenTelemetry + Aspire",
    body: "Every important flow emits logs, traces, and metrics with OTLP export, ready to light up the Aspire dashboard for full visibility.",
    cta: { label: "Explore wellness", href: "/wellness/" },
  },
];
---

<MarketingLayout
  title="Features"
  description="Everything devngn.ai does: AI-bit discovery, self-updating grounding, provider readiness, pattern intelligence, and human-first developer wellness, across CLI, VS Code, and desktop."
  active="features"
  sidebar={false}
  toc={false}
>
  <section class="page-hero">
    <div class="eyebrow">Features</div>
    <h1>One engine for your <span class="hl">AI-bits</span> and your wellbeing.</h1>
    <p class="lede">
      devngn.ai understands your machine, your tools, and the AI configuration that piles up across
      workspaces, then puts the human at the keyboard first. Here's the whole picture.
    </p>
    <div class="actions">
      <a class="btn primary" href="/download/"><Icon name="download" size={18} stroke={2.6} />Get the app</a>
      <a class="btn" href="/getting-started/">Read the docs</a>
    </div>
  </section>

  <!-- Engine: editorial sticky rail + accent-bar rows (6 capabilities) -->
  <section class="ft-engine" aria-label="The dev engine">
    <div class="ft-rail">
      <p class="ft-tag">The dev engine</p>
      <h2>Know your AI tooling, end to end.</h2>
      <p>
        OS-agnostic and vendor-aware from the start. devngn maps what you have, keeps it grounded,
        and flags what is drifting, so your agents work from the truth.
      </p>
      <a class="ft-rail-link" href="/getting-started/">Read the docs <Icon name="arrow" size={15} stroke={2.8} /></a>
    </div>
    <ol class="ft-rows">
      {
        capabilities.map((c, i) => (
          <li class="ft-row">
            <span class="ft-row-n">{String(i + 1).padStart(2, "0")}</span>
            <span class="ft-row-icon">
              <Icon name={c.icon} size={20} stroke={2.4} />
            </span>
            <div class="ft-row-copy">
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Wellness: tinted bento tiles (4 items, exact cell count) -->
  <section class="ft-wellness" aria-label="Human-first wellness">
    <header class="ft-head">
      <p class="ft-tag alt">Human-first wellness</p>
      <h2>Move more, tracked and shared.</h2>
      <p>
        A quiet, opt-in layer that turns the small gaps in a developer's day into real, compounding
        movement, never another dashboard to babysit.
      </p>
    </header>
    <div class="ft-bento">
      {
        wellness.map((c, i) => (
          <article class={`ft-tile v${i}`}>
            <span class="ft-tile-icon">
              <Icon name={c.icon} size={22} stroke={2.4} />
            </span>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Surfaces: dark band grid with CTA links (4 items) -->
  <section class="ft-surfaces" aria-label="Where it runs">
    <header class="ft-surfaces-head">
      <p class="ft-tag ghost">Where it runs</p>
      <h2>Meet you where you already work.</h2>
      <p>
        The same engine, four surfaces. Start in the terminal, live in your editor, keep the app in
        your menu bar, and watch it all in Aspire.
      </p>
    </header>
    <div class="ft-surface-grid">
      {
        surfaces.map((s) => (
          <article class="ft-surface">
            <span class="ft-surface-icon">
              <Icon name={s.icon} size={20} stroke={2.4} />
            </span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            <a class="ft-surface-link" href={s.cta.href}>
              {s.cta.label} <Icon name="arrow" size={15} stroke={2.6} />
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="cta-band">
    <h2>Put the <span class="pop">human</span> first. Know your engine cold.</h2>
    <div class="actions" style="margin-top:0">
      <a class="btn primary" href="/download/"><Icon name="download" size={18} stroke={2.6} />Download</a>
      <a class="btn alt" href="/getting-started/">Read the docs</a>
    </div>
  </section>
</MarketingLayout>

<style>
  /* Brand-signature mono tag, reused from the landing's lp-col-tag */
  .ft-tag {
    display: inline-block;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent-ink);
    background: var(--accent);
    border: 2px solid var(--ink);
    padding: 0.25rem 0.55rem;
    margin: 0 0 0.9rem;
  }
  .ft-tag.alt {
    background: var(--accent-2);
  }
  .ft-tag.ghost {
    background: transparent;
    color: var(--paper);
    border-color: var(--paper);
  }

  /* ---- Engine: sticky editorial rail + accent-bar rows ------------------ */
  .ft-engine {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 2.5rem;
    align-items: start;
  }
  .ft-rail {
    position: sticky;
    top: 6rem;
  }
  .ft-rail h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 0 0 0.6rem;
  }
  .ft-rail p:not(.ft-tag) {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
    max-width: 30rem;
  }
  .ft-rail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 3px solid var(--accent);
    padding-bottom: 2px;
  }
  .ft-rail-link svg {
    display: block;
  }

  .ft-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border);
  }
  .ft-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1.35rem 0.5rem 1.35rem 1rem;
    border-bottom: var(--border);
    border-left: 6px solid var(--accent);
    background: var(--surface-bg);
    transition: transform 0.08s ease;
  }
  .ft-row:nth-child(3n + 2) {
    border-left-color: var(--accent-2);
  }
  .ft-row:nth-child(3n + 3) {
    border-left-color: var(--accent-3);
  }
  .ft-row:hover {
    transform: translateX(4px);
  }
  .ft-row-n {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--muted);
    padding-top: 0.55rem;
  }
  .ft-row-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    flex: none;
    border: 2px solid var(--ink);
    background: var(--accent);
    color: var(--accent-ink);
    box-shadow: var(--shadow-sm);
  }
  .ft-row:nth-child(3n + 2) .ft-row-icon {
    background: var(--accent-2);
  }
  .ft-row:nth-child(3n + 3) .ft-row-icon {
    background: var(--accent-3);
  }
  .ft-row-icon svg {
    display: block;
  }
  .ft-row-copy h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    margin: 0 0 0.25rem;
  }
  .ft-row-copy p {
    margin: 0;
    line-height: 1.55;
    color: var(--text);
    font-size: 0.96rem;
  }

  /* ---- Wellness: tinted bento tiles ------------------------------------- */
  .ft-wellness {
    margin-top: 4.5rem;
  }
  .ft-head {
    max-width: 44rem;
  }
  .ft-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 0 0 0.5rem;
  }
  .ft-head p:not(.ft-tag) {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }
  .ft-bento {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .ft-tile {
    border: var(--border);
    background: var(--surface-bg);
    box-shadow: var(--shadow);
    padding: 1.6rem;
    border-top-width: 8px;
    transition:
      transform 0.08s ease,
      box-shadow 0.08s ease;
  }
  .ft-tile:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-lg);
  }
  .ft-tile-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-sm);
    color: var(--accent-ink);
    background: var(--accent);
  }
  .ft-tile-icon svg {
    display: block;
  }
  .ft-tile h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: -0.015em;
    margin: 1rem 0 0.5rem;
  }
  .ft-tile p {
    margin: 0;
    line-height: 1.55;
    color: var(--text);
  }
  .ft-tile.v0 {
    border-top-color: var(--accent);
  }
  .ft-tile.v1 {
    border-top-color: var(--accent-2);
  }
  .ft-tile.v1 .ft-tile-icon {
    background: var(--accent-2);
  }
  .ft-tile.v2 {
    border-top-color: var(--accent-3);
  }
  .ft-tile.v2 .ft-tile-icon {
    background: var(--accent-3);
  }
  /* Fourth tile is a dark feature tile for bento contrast */
  .ft-tile.v3 {
    border-top-color: var(--accent-5);
    background: #16130d;
  }
  .ft-tile.v3 .ft-tile-icon {
    background: var(--accent-5);
    border-color: var(--paper);
  }
  .ft-tile.v3 h3 {
    color: var(--paper);
  }
  .ft-tile.v3 p {
    color: #d9cfb4;
  }

  /* ---- Surfaces: full-width dark band grid ------------------------------ */
  .ft-surfaces {
    margin-top: 4.5rem;
    border: var(--border);
    background: #16130d;
    color: var(--paper);
    box-shadow: var(--shadow-lg);
    padding: 2.5rem 2rem;
  }
  .ft-surfaces-head {
    max-width: 44rem;
  }
  .ft-surfaces-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 0.5rem;
    color: var(--paper);
  }
  .ft-surfaces-head p:not(.ft-tag) {
    font-size: 1.02rem;
    color: #d9cfb4;
    line-height: 1.6;
    margin: 0;
  }
  .ft-surface-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .ft-surface {
    border: 2px solid var(--paper);
    background: #221c12;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }
  .ft-surface-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    flex: none;
    border: 2px solid var(--paper);
    background: var(--accent);
    color: var(--accent-ink);
  }
  .ft-surface:nth-child(2) .ft-surface-icon {
    background: var(--accent-2);
  }
  .ft-surface:nth-child(3) .ft-surface-icon {
    background: var(--accent-3);
  }
  .ft-surface:nth-child(4) .ft-surface-icon {
    background: var(--accent-5);
  }
  .ft-surface-icon svg {
    display: block;
  }
  .ft-surface h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    margin: 0.9rem 0 0.5rem;
    color: var(--paper);
  }
  .ft-surface p {
    margin: 0 0 1.1rem;
    line-height: 1.55;
    color: #d9cfb4;
    font-size: 0.95rem;
  }
  .ft-surface-link {
    margin-top: auto;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--paper);
    border-bottom: 3px solid var(--accent);
    padding-bottom: 2px;
  }
  .ft-surface-link svg {
    display: block;
  }

  /* ---- Responsive collapse ---------------------------------------------- */
  @media (max-width: 860px) {
    .ft-engine {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .ft-rail {
      position: static;
    }
    .ft-bento,
    .ft-surface-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .ft-row {
      grid-template-columns: auto 1fr;
    }
    .ft-row-n {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ft-row,
    .ft-tile {
      transition: none;
    }
    .ft-row:hover,
    .ft-tile:hover {
      transform: none;
    }
  }
</style>

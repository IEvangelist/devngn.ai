---
import { getBundledRegistry, getResearchFreshnessSummary } from "@devngn/vendors";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Icon from "../../components/Icon.astro";

const payload = {
  schemaVersion: 1,
  generatedAt: new Date().toISOString(),
  slogan: "Manage your AI-bits",
  research: getResearchFreshnessSummary(),
  vendors: getBundledRegistry(),
};

const json = JSON.stringify(payload, null, 2);
const vendorCount = payload.vendors.length;

/* Self-contained retro JSON highlighter, no Shiki/runtime dependency, so it
 * renders reliably in on-demand SSR and stays on-palette. */
function highlightJson(src: string): string {
  const esc = src
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
  return esc.replace(
    /("(?:\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(?:\s*:)?|\b(?:true|false)\b|\bnull\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
    (match) => {
      let cls = "t-num";
      if (/^"/.test(match)) {
        cls = /:$/.test(match) ? "t-key" : "t-str";
      } else if (match === "true" || match === "false") {
        cls = "t-bool";
      } else if (match === "null") {
        cls = "t-null";
      }
      return `<span class="${cls}">${match}</span>`;
    },
  );
}

const highlighted = highlightJson(json);
---

<MarketingLayout
  title="Vendor registry"
  description="The devngn.ai public vendor registry: a human-readable, syntax-highlighted view of the same JSON tools consume."
  active="registry"
  sidebar={false}
  toc={false}
>
  <section class="page-hero">
    <div class="eyebrow">Public registry</div>
    <h1>Vendor <span class="hl">registry</span>.</h1>
    <p class="lede">
      A human-readable, syntax-highlighted view of the {vendorCount} vendors in the devngn.ai
      registry, the exact payload tools receive from the raw endpoint.
    </p>
    <div class="actions">
      <button class="btn primary" id="copy-btn" type="button">
        <Icon name="copy" size={16} stroke={2.6} /> Copy JSON
      </button>
      <a class="btn alt" href="/registry/v1/vendors.json">
        <Icon name="code" size={16} stroke={2.6} /> Raw JSON
      </a>
      <a class="btn" href="/registry/v1/vendors.json" download="devngn-vendors.json">
        <Icon name="download" size={16} stroke={2.6} /> Download
      </a>
      <span class="copied" id="copied">Copied!</span>
    </div>
  </section>

  <div class="code-wrap">
    <div class="code-bar" aria-hidden="true">
      <span class="dot a"></span>
      <span class="dot b"></span>
      <span class="dot c"></span>
      <span class="name">vendors.json</span>
    </div>
    <pre class="json"><code set:html={highlighted} /></pre>
  </div>
</MarketingLayout>

<style>
  .code-wrap {
    border: var(--border);
    box-shadow: var(--shadow-lg);
    background: #13110b;
  }
  .code-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: var(--border);
    padding: 0.5rem 0.85rem;
    background: var(--accent-3);
  }
  .code-bar .dot {
    width: 0.85rem;
    height: 0.85rem;
    border: 2px solid var(--ink);
  }
  .code-bar .dot.a {
    background: var(--accent-5);
  }
  .code-bar .dot.b {
    background: var(--accent);
  }
  .code-bar .dot.c {
    background: var(--accent-2);
  }
  .code-bar .name {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--accent-ink);
    margin-left: 0.35rem;
  }
  .code-wrap pre.json {
    margin: 0;
    padding: 1.25rem 1.4rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.6;
    color: #ece0c2;
    white-space: pre;
    tab-size: 2;
  }
  .code-wrap pre.json :global(.t-key) {
    color: #ffae66;
  }
  .code-wrap pre.json :global(.t-str) {
    color: #5fe3cb;
  }
  .code-wrap pre.json :global(.t-num) {
    color: #c3a6ff;
  }
  .code-wrap pre.json :global(.t-bool) {
    color: #ff8aa6;
  }
  .code-wrap pre.json :global(.t-null) {
    color: #9b906f;
    font-style: italic;
  }
  .copied {
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent-ink);
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .copied.show {
    opacity: 1;
  }
</style>

<script is:inline>
  (() => {
    const wire = () => {
      const btn = document.getElementById("copy-btn");
      const note = document.getElementById("copied");
      const code = document.querySelector(".code-wrap pre.json");
      if (!btn || btn.dataset.wired) return;
      btn.dataset.wired = "1";
      btn.addEventListener("click", async () => {
        const data = code?.innerText ?? "";
        try {
          await navigator.clipboard.writeText(data);
          note?.classList.add("show");
          setTimeout(() => note?.classList.remove("show"), 1600);
        } catch {}
      });
    };
    wire();
    document.addEventListener("astro:page-load", wire);
  })();
</script>

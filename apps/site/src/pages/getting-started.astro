---
/*
 * Getting started guide. Renders the markdown in src/docs/getting-started.md
 * through the shared MarketingLayout shell so the docs wear the exact same
 * chrome (header, sidebar, TOC, footer, hero) as every other subpage.
 */
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { Content, frontmatter } from "../docs/getting-started.md";

export const prerender = true;
---

<MarketingLayout
  title={frontmatter.title}
  description={frontmatter.description}
  active="docs"
  sidebar={false}
>
  <section class="page-hero">
    <div class="eyebrow">Guide</div>
    <h1>Getting <span class="hl">started</span></h1>
    <p class="lede">{frontmatter.description}</p>
  </section>
  <div class="sl-markdown-content">
    <Content />
  </div>
</MarketingLayout>

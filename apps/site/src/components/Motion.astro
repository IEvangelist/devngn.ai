---
/*
 * Motion driver for the marketing shell. Rendered early in <head> (via
 * MarketingLayout) so the `motion` flag lands on <html> before first paint:
 * every hidden pre-animation state in marketing.css is gated behind
 * `html.motion`, so no-JS and reduced-motion visitors always see fully
 * rendered content and nothing can get stuck invisible.
 *
 * Responsibilities:
 *   - Scroll reveal (robust: scroll-math primary + IntersectionObserver +
 *     failsafe, so below-fold blocks always appear even in embedded webviews).
 *   - Scroll-progress bar (writes 0..1 to --sp on <html>).
 *   - Hero parallax on the live-proof card (via the `translate` property, which
 *     composes with the entrance `transform` animation).
 *   - Count-up on the hero live-proof numbers.
 *   - Magnetic buttons + card tilt (pointer:fine only).
 *
 * Works with Astro's <ClientRouter />:
 *   - `astro:after-swap` re-adds the flag pre-paint (Astro wipes <html> classes
 *     on navigation, same as the theme attribute).
 *   - `astro:page-load` re-runs everything for the freshly swapped page.
 */
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const fine = window.matchMedia("(pointer: fine)");

    // Set the pre-paint flag (also called on nav via astro:after-swap).
    const setFlag = () => root.classList.toggle("motion", !reduce.matches);
    setFlag();

    if (window.__motionBound) return;
    window.__motionBound = true;

    // Top-level content blocks. Landing hero + its works strip run their own
    // on-load entrance, so they are excluded here (matches marketing.css).
    const SELECTOR = ".shell-main > *, .lp > *:not(.lp-hero):not(.lp-works)";
    const reveal = (el) => el.classList.add("in-view");

    /* ---- Scroll reveal ---------------------------------------------------- *
     * Robust by design: a plain scroll/resize math check is the primary
     * driver (works in any embedded webview), with IntersectionObserver as a
     * bonus and a short failsafe. Anything at/above the fold is shown on init,
     * so content can never get stuck invisible. */
    let pending = [];
    let io = null;
    const vh = () => window.innerHeight || root.clientHeight;
    const drop = (el) => {
      pending = pending.filter((e) => e !== el);
      if (io) io.unobserve(el);
    };
    const revealInView = () => {
      if (reduce.matches) {
        pending.forEach(reveal);
        pending = [];
        return;
      }
      for (const el of pending.slice()) {
        if (el.getBoundingClientRect().top < vh() * 0.92) {
          reveal(el);
          drop(el);
        }
      }
    };

    /* ---- Scroll progress (0..1 written to --sp on <html>) ----------------- */
    const updateProgress = () => {
      const max = root.scrollHeight - root.clientHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      root.style.setProperty("--sp", p.toFixed(4));
    };

    /* ---- Hero parallax (translate composes with the entrance transform) --- */
    let heroArt = null;
    const parallax = () => {
      if (!heroArt || reduce.matches) return;
      const y = Math.min(window.scrollY, 700);
      heroArt.style.translate = "0 " + (y * 0.07).toFixed(1) + "px";
    };

    let sTick = false;
    const onScroll = () => {
      if (sTick) return;
      sTick = true;
      requestAnimationFrame(() => {
        sTick = false;
        revealInView();
        updateProgress();
        parallax();
      });
    };

    /* ---- Count-up on the hero live-proof numbers -------------------------- */
    const countUp = (el, target) => {
      const dur = 950;
      const t0 = performance.now();
      const tick = (now) => {
        const t = Math.min(1, (now - t0) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(target * eased).toString();
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = target.toString();
      };
      requestAnimationFrame(tick);
    };
    const initCounts = () => {
      if (reduce.matches) return;
      document.querySelectorAll(".lp-proof-card dd").forEach((dd) => {
        const raw = (dd.textContent || "").trim();
        if (/^\d+$/.test(raw) && !dd.dataset.counted) {
          dd.dataset.counted = "1";
          dd.textContent = "0";
          countUp(dd, parseInt(raw, 10));
        }
      });
    };

    /* ---- Magnetic buttons (translate; pointer:fine only) ------------------ */
    const bindMagnetic = (btn) => {
      const pull = 12;
      btn.addEventListener("pointermove", (e) => {
        const r = btn.getBoundingClientRect();
        const mx = (e.clientX - (r.left + r.width / 2)) / r.width;
        const my = (e.clientY - (r.top + r.height / 2)) / r.height;
        btn.style.translate =
          (mx * pull).toFixed(1) + "px " + (my * pull).toFixed(1) + "px";
      });
      const reset = () => (btn.style.translate = "0 0");
      btn.addEventListener("pointerleave", reset);
      btn.addEventListener("blur", reset);
    };
    const initMagnetic = () => {
      if (!fine.matches || reduce.matches) return;
      document
        .querySelectorAll(".lp-hero .actions .btn, .cta-band .btn")
        .forEach((b) => {
          if (!b.dataset.mag) {
            b.dataset.mag = "1";
            bindMagnetic(b);
          }
        });
    };

    /* ---- Tilt the hero proof card toward the cursor ----------------------- */
    const bindTilt = (card) => {
      const max = 7;
      // The entrance animation (fill: both) owns `transform`; release it so the
      // hover tilt can take over once the intro has played.
      const release = () => (card.style.animation = "none");
      card.addEventListener("animationend", release, { once: true });
      setTimeout(release, 1200);
      card.addEventListener("pointermove", (e) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform =
          "perspective(900px) rotateX(" +
          (-py * max).toFixed(2) +
          "deg) rotateY(" +
          (px * max).toFixed(2) +
          "deg)";
      });
      const reset = () => (card.style.transform = "perspective(900px)");
      card.addEventListener("pointerleave", reset);
    };
    const initTilt = () => {
      if (!fine.matches || reduce.matches) return;
      document.querySelectorAll(".lp-proof-card").forEach((c) => {
        if (!c.dataset.tilt) {
          c.dataset.tilt = "1";
          bindTilt(c);
        }
      });
    };

    /* ---- Cursor aura: a fluid two-tone blob that trails the pointer -------- *
     * A soft fuchsia(left)/teal(right) gradient blob (#cursor-aura, styled in
     * marketing.css at z-index -1 so it only shows through the dotted gaps)
     * springs toward the cursor, squashes & stretches with its own velocity,
     * and bounces off the major content blocks + viewport edges it runs into —
     * so it reads as a living pool of brand colour, never a rigid circle.
     * Pointer:fine + no-reduced-motion only.                                   */
    let auraEl = null;
    const auraTarget = { x: 0, y: 0 };
    const auraPos = { x: 0, y: 0 };
    const auraVel = { x: 0, y: 0 };
    let auraObstacles = [];
    let auraRAF = 0;
    let auraSeen = false;
    const AURA_R = 96; // collision radius (px)
    const REST = 0.7; // restitution (bounciness)

    const ensureAura = () => {
      auraEl = document.getElementById("cursor-aura");
      if (!auraEl) {
        auraEl = document.createElement("div");
        auraEl.id = "cursor-aura";
        auraEl.setAttribute("aria-hidden", "true");
        document.body.appendChild(auraEl);
      }
      return auraEl;
    };
    const gatherObstacles = () => {
      // Only genuinely "boxed" components (a border or solid/painted bg) act as
      // walls — transparent text wrappers like the hero copy are skipped so the
      // blob glides behind them instead of getting trapped. Page-tall wrappers
      // are excluded too.
      const sel =
        ".site-topbar, .lp-proof-card, .lp-works, .lp-band, .art-grounding, " +
        ".art-readiness, .cta-band, .lp-band-figs > *, [class*='card'], " +
        "[class*='panel'], figure, .sl-markdown-content pre, " +
        ".sl-markdown-content table, .sl-markdown-content blockquote";
      const vw = window.innerWidth;
      auraObstacles = [...document.querySelectorAll(sel)]
        .filter((el) => {
          const r = el.getBoundingClientRect();
          if (r.width < 48 || r.height < 32) return false;
          if (r.width > vw * 0.92 && r.height > 900) return false;
          const cs = getComputedStyle(el);
          const bordered =
            parseFloat(cs.borderTopWidth) > 0 && cs.borderTopStyle !== "none";
          const bg = cs.backgroundColor;
          const solidBg = !!bg && !bg.endsWith(", 0)") && bg !== "transparent";
          return bordered || solidBg || cs.backgroundImage !== "none";
        })
        .slice(0, 36);
    };

    // Circle-vs-rect: eject the blob from any block it overlaps, then bounce.
    const collide = (rect) => {
      const cx = Math.max(rect.left, Math.min(auraPos.x, rect.right));
      const cy = Math.max(rect.top, Math.min(auraPos.y, rect.bottom));
      let nx = auraPos.x - cx;
      let ny = auraPos.y - cy;
      const d2 = nx * nx + ny * ny;
      if (d2 > AURA_R * AURA_R) return;
      if (d2 > 0.0001) {
        const d = Math.sqrt(d2);
        nx /= d;
        ny /= d;
        const overlap = AURA_R - d;
        auraPos.x += nx * overlap;
        auraPos.y += ny * overlap;
      } else {
        // Centre is inside the block: eject through the nearest edge.
        const dl = auraPos.x - rect.left;
        const dr = rect.right - auraPos.x;
        const dt = auraPos.y - rect.top;
        const db = rect.bottom - auraPos.y;
        const m = Math.min(dl, dr, dt, db);
        nx = m === dl ? -1 : m === dr ? 1 : 0;
        ny = m === dt ? -1 : m === db ? 1 : 0;
        auraPos.x += nx * (m + AURA_R);
        auraPos.y += ny * (m + AURA_R);
      }
      const dot = auraVel.x * nx + auraVel.y * ny;
      if (dot < 0) {
        auraVel.x -= (1 + REST) * dot * nx;
        auraVel.y -= (1 + REST) * dot * ny;
      }
    };

    const auraStep = () => {
      auraRAF = 0;
      // Spring toward the cursor for a fluid, trailing follow.
      auraVel.x = (auraVel.x + (auraTarget.x - auraPos.x) * 0.08) * 0.82;
      auraVel.y = (auraVel.y + (auraTarget.y - auraPos.y) * 0.08) * 0.82;
      auraPos.x += auraVel.x;
      auraPos.y += auraVel.y;

      const vw = window.innerWidth;
      const vh2 = vh();
      // Bounce off nearby content blocks (broad-phase cull by viewport first).
      for (const el of auraObstacles) {
        const r = el.getBoundingClientRect();
        if (r.bottom < -40 || r.top > vh2 + 40 || r.right < 0 || r.left > vw)
          continue;
        collide(r);
      }
      // Keep it on screen.
      if (auraPos.x < 0) {
        auraPos.x = 0;
        auraVel.x = Math.abs(auraVel.x) * REST;
      } else if (auraPos.x > vw) {
        auraPos.x = vw;
        auraVel.x = -Math.abs(auraVel.x) * REST;
      }
      if (auraPos.y < 0) {
        auraPos.y = 0;
        auraVel.y = Math.abs(auraVel.y) * REST;
      } else if (auraPos.y > vh2) {
        auraPos.y = vh2;
        auraVel.y = -Math.abs(auraVel.y) * REST;
      }

      // Velocity-driven squash & stretch + a slight lean into the motion.
      const sp = Math.hypot(auraVel.x, auraVel.y);
      const s = Math.min(sp * 0.012, 0.22);
      const sx = (1 + s).toFixed(3);
      const sy = (1 - s * 0.7).toFixed(3);
      const rot = Math.max(-16, Math.min(16, auraVel.x * 0.6)).toFixed(2);
      if (auraEl) {
        auraEl.style.transform =
          "translate3d(" +
          auraPos.x.toFixed(1) +
          "px," +
          auraPos.y.toFixed(1) +
          "px,0) rotate(" +
          rot +
          "deg) scale(" +
          sx +
          "," +
          sy +
          ")";
        // Single hue that shifts with the pointer's horizontal position:
        // fuchsia on the left of the viewport, blending to teal on the right.
        const t = Math.max(0, Math.min(1, auraTarget.x / vw));
        auraEl.style.setProperty("--aura-mix", (t * 100).toFixed(1) + "%");
      }
      // Keep animating while it still has energy or is chasing the cursor.
      const restless =
        sp > 0.15 ||
        Math.abs(auraTarget.x - auraPos.x) > 0.5 ||
        Math.abs(auraTarget.y - auraPos.y) > 0.5;
      if (restless) auraRAF = requestAnimationFrame(auraStep);
    };
    const kickAura = () => {
      if (!auraRAF) auraRAF = requestAnimationFrame(auraStep);
    };
    const onAura = (e) => {
      auraTarget.x = e.clientX;
      auraTarget.y = e.clientY;
      if (!auraSeen) {
        auraSeen = true;
        auraPos.x = e.clientX;
        auraPos.y = e.clientY;
      }
      root.style.setProperty("--aura", "1");
      kickAura();
    };
    const auraOff = () => root.style.setProperty("--aura", "0");
    const initAura = () => {
      if (!fine.matches || reduce.matches) return;
      window.addEventListener("pointermove", onAura, { passive: true });
      document.addEventListener("pointerleave", auraOff);
      window.addEventListener("blur", auraOff);
    };

    const run = () => {
      // (Re)collect reveal targets for the freshly swapped page.
      pending = [...document.querySelectorAll(SELECTOR)].filter(
        (el) => !el.classList.contains("in-view"),
      );
      if (!reduce.matches && "IntersectionObserver" in window) {
        io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting || entry.boundingClientRect.top < 0) {
                reveal(entry.target);
                drop(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -6% 0px", threshold: 0.05 },
        );
        pending.forEach((el) => io.observe(el));
      }
      revealInView();

      heroArt = document.querySelector(".lp-proof-card");
      updateProgress();
      parallax();
      initCounts();
      initMagnetic();
      initTilt();
      ensureAura();
      gatherObstacles();

      // Failsafe: never leave the initial viewport blank if a callback misfires.
      setTimeout(revealInView, 1000);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener(
      "resize",
      () => {
        revealInView();
        updateProgress();
        parallax();
        gatherObstacles();
      },
      { passive: true },
    );
    window.addEventListener("load", revealInView);
    initAura();
    document.addEventListener("astro:after-swap", setFlag);
    document.addEventListener("astro:page-load", run);
    reduce.addEventListener?.("change", setFlag);
  })();
</script>

---
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./Icon.astro";
import { navLinks } from "./nav-links";

interface Props {
  active?: string;
}

const { active } = Astro.props;
---

<header class="site-topbar">
  <a class="site-brand" href="/">devngn<span class="dot">.</span>ai</a>
  <div class="site-topbar-right">
    <nav class="site-topnav" aria-label="Primary">
      {
        navLinks.map((l) => (
          <a
            href={l.href}
            class:list={["site-navlink", { "is-active": active === l.id }]}
            aria-current={active === l.id ? "page" : undefined}
            {...(l.external ? { rel: "noopener", target: "_blank" } : {})}
          >
            <Icon name={l.icon} size={14} stroke={2.6} />
            <span>{l.label}</span>
          </a>
        ))
      }
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-topbar {
    max-width: 1140px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .site-brand {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.4rem;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--ink);
  }
  .site-brand .dot {
    color: var(--accent);
  }
  .site-topbar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .site-topnav {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .site-navlink {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    padding: 0.4rem 0.7rem;
    border: 2px solid transparent;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
  }
  .site-navlink :global(svg) {
    display: block;
  }
  .site-navlink:hover {
    border-color: var(--ink);
    background: var(--accent-3);
    color: var(--accent-ink);
  }
  .site-navlink.is-active {
    border-color: var(--ink);
    background: var(--accent);
    color: var(--accent-ink);
  }
</style>

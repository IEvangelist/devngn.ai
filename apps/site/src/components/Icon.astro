---
/*
 * Retro energy icon pack — dependency-free inline SVG.
 * Consistent neo-brutalist geometry: chunky strokes, square caps, miter joins.
 */
interface Props {
  name: string;
  size?: number | string;
  class?: string;
  label?: string;
  stroke?: number;
}

const { name, size = 24, class: className, label, stroke = 2.4 } = Astro.props;

const icons: Record<string, string> = {
  eye: '<path d="M2 12 12 5l10 7-10 7z"/><circle cx="12" cy="12" r="3"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l4 2"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6z"/>',
  pulse: '<path d="M2 12h4l3-8 4 16 3-8h6"/>',
  target:
    '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.6"/>',
  trophy:
    '<path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3M9 14h6M8 20h8M10 14l-1 6M14 14l1 6"/>',
  people:
    '<circle cx="8" cy="8" r="3"/><circle cx="17" cy="9" r="2.4"/><path d="M3 20a5 5 0 0 1 10 0M14 19.4A4 4 0 0 1 21 19"/>',
  heart: '<path d="M12 21 4 13a4.6 4.6 0 0 1 7-5l1 1 1-1a4.6 4.6 0 0 1 7 5z"/>',
  check: '<rect x="3" y="3" width="18" height="18"/><path d="M7 12l3.4 3.4L17 8"/>',
  calendar:
    '<rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/><circle cx="15.5" cy="15" r="2.2"/>',
  bell: '<path d="M6 9a6 6 0 0 1 12 0c0 6 3 6 3 9H3c0-3 3-3 3-9z"/><path d="M10 21a2 2 0 0 0 4 0"/>',
  flame:
    '<path d="M12 2c4 4 6 7 6 11a6 6 0 0 1-12 0c0-2 1-4 3-5 0 2 1 3 2 3 0-4-2-6 1-10z"/>',
  sun: '<circle cx="12" cy="12" r="5"/><path d="M12 1v3M12 20v3M1 12h3M20 12h3M4 4l2.2 2.2M17.8 17.8 20 20M20 4l-2.2 2.2M6.2 17.8 4 20"/>',
  moon: '<path d="M20 14A8 8 0 0 1 10 4a8 8 0 1 0 10 10z"/>',
  spark: '<path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/>',
  book: '<path d="M4 4h7a2 2 0 0 1 2 2v14a2 2 0 0 0-2-2H4z"/><path d="M20 4h-7a2 2 0 0 0-2 2v14a2 2 0 0 1 2-2h7z"/>',
  code: '<path d="M8 7l-5 5 5 5M16 7l5 5-5 5"/>',
  arrow: '<path d="M4 12h15M13 6l6 6-6 6"/>',
  download: '<path d="M12 3v12M7 11l5 5 5-5M4 21h16"/>',
  copy: '<rect x="9" y="9" width="11" height="11"/><path d="M5 15V5a1 1 0 0 1 1-1h9"/>',
  braces:
    '<path d="M8 3c-2 0-3 1-3 3v2c0 2-1 2-2 2 1 0 2 0 2 2v3c0 2 1 3 3 3M16 3c2 0 3 1 3 3v2c0 2 1 2 2 2-1 0-2 0-2 2v3c0 2-1 3-3 3"/>',
  github:
    '<path d="M9 19c-4 1.4-4-2-6-2.5m12 4.5v-3.4c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12 12 0 0 0-6 0C6.6 2.2 5.5 2.5 5.5 2.5a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 8.9c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V20"/>',
  globe:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
  file:
    '<path d="M6 2h8l4 4v16H6z"/><path d="M14 2v4h4"/><path d="M9 12h6M9 16h6"/>',
  shield:
    '<path d="M12 2 4 5v6c0 5 3.4 8 8 11 4.6-3 8-6 8-11V5z"/><path d="M8.5 12l2.4 2.4L16 9.5"/>',
  mail: '<rect x="3" y="5" width="18" height="14"/><path d="M3 6l9 7 9-7"/>',
  tag: '<path d="M12 3H3v9l9 9 9-9z"/><circle cx="7.5" cy="7.5" r="1.5"/>',
  rocket:
    '<path d="M12 3c3 1 6 4 6 9l-3 3H9l-3-3c0-5 3-8 6-9z"/><circle cx="12" cy="9" r="1.8"/><path d="M9 18l-3 3M15 18l3 3"/>',
};

const path = icons[name] ?? icons.spark;
const dim = typeof size === "number" ? `${size}` : size;
const decorative = !label;
---

<svg
  class={className}
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="square"
  stroke-linejoin="miter"
  role={decorative ? undefined : "img"}
  aria-hidden={decorative ? "true" : undefined}
  aria-label={label}
  set:html={path}
/>

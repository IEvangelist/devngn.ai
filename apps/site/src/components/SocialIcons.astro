---
// Starlight override: inject the canonical site nav (same links as the
// marketing SiteHeader) into the docs header, then render the default
// SocialIcons so any configured socials + the slot pass through.
import Default from "@astrojs/starlight/components/SocialIcons.astro";
import Icon from "./Icon.astro";
import { navLinks } from "./nav-links";
---

<nav class="sl-topnav" aria-label="Site">
  {
    navLinks.map((l) => (
      <a
        href={l.href}
        class="sl-navlink"
        {...(l.external ? { rel: "noopener", target: "_blank" } : {})}
      >
        <Icon name={l.icon} size={14} stroke={2.6} />
        <span>{l.label}</span>
      </a>
    ))
  }
</nav>
<Default><slot /></Default>

<style>
  .sl-topnav {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .sl-navlink {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 700;
    text-decoration: none;
    color: var(--ink);
    padding: 0.3rem 0.5rem;
    border: 2px solid transparent;
    line-height: 1;
  }
  .sl-navlink :global(svg) {
    display: block;
  }
  .sl-navlink:hover {
    border-color: var(--ink);
    background: var(--accent-3);
    color: var(--accent-ink);
  }
  /* On narrow viewports the docs sidebar already provides navigation. */
  @media (max-width: 50rem) {
    .sl-topnav {
      display: none;
    }
  }
</style>

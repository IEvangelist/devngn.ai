---
// Shared marketing/docs footer so every standalone page ends the same way.
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <span class="site-footer-license">MIT · Copyright © 2026–Present David Pine</span>
    <nav class="site-footer-links" aria-label="Footer">
      <a href="/getting-started/">Docs</a>
      <a href="/wellness/">Wellness</a>
      <a href="/wellness/reference">API reference</a>
      <a href="/registry/">Registry</a>
      <a href="/registry/v1/vendors.json">Registry JSON (raw)</a>
      <a href="https://github.com/IEvangelist/devngn.ai">GitHub</a>

# Copy these names into the Netlify project environment for apps/site.
# For direct Astro development, you can also copy them into apps/site/.env.local.

# Required: GitHub OAuth web flow.
GITHUB_OAUTH_CLIENT_ID=github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=github-oauth-client-secret

# Optional: set this only when device flow uses a different GitHub OAuth app.
# If omitted, device flow falls back to GITHUB_OAUTH_CLIENT_ID.
GITHUB_DEVICE_OAUTH_CLIENT_ID=github-device-oauth-client-id

# Required: Base64 JWT signing key that decodes to at least 32 bytes.
# Generate one with: openssl rand -base64 32
JWT_SECRET=
JWT_ISSUER=https://devngn.ai
JWT_AUDIENCE=devngn-wellness-api

# Optional: runtime JWT tuning.
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=3600
JWT_KEY_ID=v1

# Optional: extends the built-in exact allow-list
# (https://devngn.ai, http://tauri.localhost, https://tauri.localhost, tauri://localhost).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321,http://localhost:8888

# Required in linked Netlify environments; Netlify Database injects this automatically.
# Only set it manually when running outside a linked Netlify environment.
NETLIFY_DB_URL=postgres://localhost:5432/devngn_wellness

# Optional: Google Calendar OAuth. Configure all three together or leave all unset.
GOOGLE_CALENDAR_CLIENT_ID=google-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=google-calendar-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=https://devngn.ai/v1/schedule/callback/google

# Optional: Microsoft Calendar OAuth. Configure all three together or leave all unset.
MICROSOFT_CALENDAR_CLIENT_ID=microsoft-calendar-client-id
MICROSOFT_CALENDAR_CLIENT_SECRET=microsoft-calendar-client-secret
MICROSOFT_CALENDAR_REDIRECT_URI=https://devngn.ai/v1/schedule/callback/microsoft
MICROSOFT_CALENDAR_TENANT_ID=common

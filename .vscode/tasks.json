{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "devngn: install",
      "type": "shell",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: build VS Code extension",
      "type": "shell",
      "command": "pnpm --filter devngn-ai-vscode build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "devngn: build CLI",
      "type": "shell",
      "command": "pnpm --filter @devngn/cli build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "devngn: build API and vendors",
      "type": "shell",
      "command": "pnpm --filter @devngn/api build && pnpm --filter @devngn/vendors build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "devngn: build workspace",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: test workspace",
      "type": "shell",
      "command": "pnpm test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: lint workspace",
      "type": "shell",
      "command": "pnpm lint",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: format check",
      "type": "shell",
      "command": "pnpm format",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: restore Aspire comms AppHost",
      "type": "shell",
      "command": "pnpm --filter @devngn/comms-apphost restore",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "devngn: start Aspire comms AppHost",
      "type": "shell",
      "command": "pnpm dev:comms",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
